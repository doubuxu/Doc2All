  {
    "type": "text",
    "text": "NTKs for (Graph) Neural Networks are not shift invariant ",
    "bbox": [
      15,
      230,
      146,
      273
    ],
    "page_idx": 0
  },
  {
    "type": "image",
    "img_path": "output/Accurate and Scalable Estimation of Epistemic Uncertainty for Graph Neural Networks_poster/visuals/images/fig_1.jpg",
