    ],
    "page_idx": 0
  },
  {
    "type": "text",
    "text": "Posteriordensity ",
    "bbox": [
      46,
      902,
      89,
      913
    ],
    "page_idx": 0
  },
  {
    "type": "text",
    "text": "Gaussian posterior approximation by Vl ",
    "bbox": [
      46,
      929,
      144,
      940
    ],
    "page_idx": 0
  },
  {
    "type": "text",
    "text": "Posteriordensity ",
    "bbox": [
      168,
      901,
      222,
      913
    ],
    "page_idx": 0
  },
  {
    "type": "text",
    "text": "←Datapoint-wise MCMC over the latent z ",
    "bbox": [
      168,
      928,
      275,
      940
    ],
    "page_idx": 0
  },
  {
    "type": "text",
    "text": "(a)Variational inference ",
    "bbox": [
      57,
      952,
      141,
      966
    ],
    "page_idx": 0
  },
  {
    "type": "text",
    "text": "(b) Langevindynamics ",
    "bbox": [
      191,
      952,
      273,
