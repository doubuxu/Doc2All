      338,
      777
    ],
    "page_idx": 0
  },
  {
    "type": "image",
    "img_path": "output/Truly Scale-Equivariant Deep Nets with Fourier Layers_poster/visuals/images/fig_5.jpg",
    "image_caption": [],
    "image_footnote": [],
    "bbox": [
