<tr><td>GPRGN</td><td>62.59±2.04</td><td>46.31±2.46</td><td>78.11±6.55</td><td>81.35±5.32</td><td>82.55±6.23</td><td>35.16±0.90</td><td>5.17</td></tr><tr><td>GCNII</td><td>63.86±3.04</td><td>38.47±1.58</td><td>77.86±3.79</td><td>80.39±3.83</td><td>77.57±3.40</td><td>37.44±1.30</td><td>5.83</td></tr><tr><td>COCN (OURS)</td><td>79.17±0.17</td><td>72.95±0.23</td><td>86.22±0.49</td><td>85.21±0.49</td><td>86.88±0.45</td><td>36.35±0.12</td><td>1.83</td></tr></table>",
