1.53</td><td>72.06±0.64</td><td>50.23±0.53</td><td>77.27±0.51</td></tr><tr><td>EDGEPOOL</td><td>74.17±1.82</td><td>75.12±0.76</td><td>-</td><td>72.46±0.74</td><td>50.79±0.59</td><td>-</td></tr><tr><td>SEP</td><td>85.56±1.09</td><td>76.42±0.39</td><td>79.35±0.33</td><td>74.12±0.56</td><td>51.53±0.65</td><td>81.28±0.15</td></tr><tr><td>GMT</td><td>83.44±1.33</td><td>75.09±0.59</td><td>76.35±2.62</td><td>73.48±0.76</td><td>50.66±0.82</td><td>80.74±0.54</td></tr><tr><td>COCN (OURS)</td><td>87.08±0.17</td><td>76.86±0.13</td><td>82.89±0.19</td><td>77.26±0.27</td><td>56.32±0.18</td><td>86.15±0.10</td></tr></table>",
    "bbox": [
