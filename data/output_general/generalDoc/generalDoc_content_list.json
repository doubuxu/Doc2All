span=1 colspan=1>Z11CS1105</td><td rowspan=1 colspan=1>计算智能</td><td rowspan=1 colspan=1>48</td><td rowspan=1 colspan=1>3</td><td rowspan=1 colspan=1>考查</td><td rowspan=1 colspan=1>秋季</td><td rowspan=1 colspan=1>计算机学院</td></tr><tr><td rowspan=1 colspan=1>Z11CS1107</td><td rowspan=1 colspan=1>模糊系统理论与应用</td><td rowspan=1 colspan=1>48</td><td rowspan=1 colspan=1>3</td><td rowspan=1 colspan=1>考试</td><td rowspan=1 colspan=1>春季</td><td rowspan=1 colspan=1>计算机学院</td></tr><tr><td rowspan=1 colspan=1>Z11CS1202</td><td rowspan=1 colspan=1>Petri网原理及应用</td><td rowspan=1 colspan=1>40</td><td rowspan=1 colspan=1>2</td><td rowspan=1 colspan=1>考查</td><td rowspan=1 colspan=1>秋季</td><td rowspan=1 colspan=1>计算机学院</td></tr><tr><td rowspan=1 colspan=1>X24CS1132</td><td rowspan=1 colspan=1>面向对象技术</td><td rowspan=1 colspan=1>48</td><td rowspan=1 colspan=1>3</td><td rowspan=1 colspan=1>考试</td><td rowspan=1 colspan=1>秋季</td><td rowspan=1 colspan=1>计算机学院</td></tr><tr><td rowspan=1 colspan=8>可在全校硕士课程中选修</td></tr></table>",
        "bbox": [
            78,
