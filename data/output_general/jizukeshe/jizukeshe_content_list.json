    {
        "type": "table",
        "img_path": "/data/huangyc/Document2All/data/output_general/jizukeshe/visuals/tables/table_11.jpg",
        "table_caption": [],
        "table_footnote": [],
        "table_body": "<table><tr><td>地址 （二进制）</td><td>内容 （二进制）</td><td>助记符</td><td>说明</td></tr><tr><td>0000 0000</td><td>00000000</td><td>IN</td><td>&quot;INPUT DEVICE—&gt; RO</td></tr><tr><td>0000 0001</td><td>0111 0000</td><td>SHL</td><td>R0 = RO+RO</td></tr><tr><td>0000 0010</td><td>0000 1010</td><td></td><td></td></tr><tr><td>0000 0011</td><td>0001 0000</td><td>SUB [0BH]</td><td>R0 = R0 - [OBH]</td></tr><tr><td>0000 0100</td><td>0000 1011</td><td></td><td></td></tr><tr><td>0000 0101</td><td>0010 0000</td><td>INC</td><td>R0 =R0+1</td></tr><tr><td>0000 0110</td><td>00110000</td><td>XOR [0CH]</td><td>R0 = RO xor [0CH]</td></tr><tr><td>0000 0111</td><td>0000 1100</td><td></td><td></td></tr><tr><td>0000 1000</td><td>0100 0000</td><td>CLR</td><td>R0 = 0</td></tr><tr><td>0000 1001</td><td>0101 0000</td><td>NOT</td><td>RO = !RO</td></tr><tr><td>0000 1010</td><td>0110 0000</td><td>STA [OD]</td><td>[0D] = R0</td></tr><tr><td>0000 1011</td><td>0000 1101</td><td></td><td></td></tr></table>",
        "bbox": [
