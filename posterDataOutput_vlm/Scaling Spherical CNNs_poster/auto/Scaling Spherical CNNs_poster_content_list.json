        ],
        "page_idx": 0
    },
    {
        "type": "text",
        "text": "Cohen etal(ICLR18),Esteves etal (ECCV'18,NeurlPS'2O),Kondoretal(NeurlP'18), Cobb et al(ICLR'21),McEwen et al (ICLR'22),Ocampo et al (ICLR'23). ",
        "bbox": [
            260,
            569,
            471,
            600
        ],
        "page_idx": 0
    },
    {
        "type": "text",
        "text": "Molecular property regression ",
        "text_level": 1,
        "bbox": [
            648,
