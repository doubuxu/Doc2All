        "page_idx": 0
    },
    {
        "type": "text",
        "text": "Sixclasses of biophysical data relevanttoantibodydevelopmentare (a) expression,(b) thermostability,(c) immunogenicity,(d) binding affinity,(e) aggregation,and (f)polyreactivity ",
        "bbox": [
