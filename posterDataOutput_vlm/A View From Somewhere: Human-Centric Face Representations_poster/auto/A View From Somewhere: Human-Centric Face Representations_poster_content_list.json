        ],
        "page_idx": 0
    },
    {
        "type": "text",
        "text": "Using1o-foldcrossvalidation,wetrainlinearSVMs todiscriminatebetweenannotatormasksfrom two different annotator subgroups. ",
        "bbox": [
            860,
            634,
            966,
            662
        ],
        "page_idx": 0
    },
    {
        "type": "text",
